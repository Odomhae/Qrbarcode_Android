<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <EditText
        android:id="@+id/editText"
        android:hint="@string/hint_content_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_white"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:padding="16dp"
        android:textSize="16sp"
        android:elevation="2dp"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:id="@+id/svContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Customization Panel -->
            <LinearLayout
                android:id="@+id/customizationPanel"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/customization_panel_background"
                android:padding="12dp">

                <!-- Color Selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_color_selection"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_foreground_color"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="4dp">

                            <View
                                android:id="@+id/foregroundColorPreview"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/color_preview_background"
                                android:backgroundTint="@android:color/black" />

                            <Button
                                android:id="@+id/btnPickForegroundColor"
                                android:text="@string/btn_select"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:background="@drawable/btn_secondary_background" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_background_color"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="4dp">

                            <View
                                android:id="@+id/backgroundColorPreview"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/color_preview_background"
                                android:backgroundTint="@color/white" />

                            <Button
                                android:id="@+id/btnPickBackgroundColor"
                                android:text="@string/btn_select"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:background="@drawable/btn_secondary_background" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_border_color"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="4dp">

                            <View
                                android:id="@+id/borderColorPreview"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/color_preview_background"
                                android:backgroundTint="@android:color/black" />

                            <Button
                                android:id="@+id/btnPickBorderColor"
                                android:text="@string/btn_select"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:background="@drawable/btn_secondary_background" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Image Options -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_image_options"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <CheckBox
                        android:id="@+id/checkAddImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_image_option"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_blue" />

                    <Button
                        android:id="@+id/btnSelectImage"
                        android:text="@string/btn_gallery"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/btn_secondary_background"
                        android:elevation="2dp" />

                    <Button
                        android:id="@+id/btnTakePhoto"
                        android:text="@string/btn_camera"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:enabled="false"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:background="@drawable/btn_secondary_background"
                        android:elevation="2dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/selectedImagePreview"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:background="@drawable/color_preview_background"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Banner Ad -->
            <com.google.android.gms.ads.AdView
                android:id="@+id/adView_generate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:adSize="BANNER"
                app:adUnitId="@string/ad_unit_id_banner_generate" />

            <ImageView
                android:id="@+id/imageView"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="20dp"
                android:scaleType="fitCenter"
                android:background="@color/surface_white"
                android:elevation="4dp"
                android:padding="8dp"/>

        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/buttonGenerate"
            android:text="@string/btn_generate_qr"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/btn_primary_background"
            android:elevation="4dp" />

    </LinearLayout>

    <Button
        android:id="@+id/buttonShare"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="@string/btn_share"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_secondary_background"
        android:elevation="2dp"
        android:visibility="gone" />


</LinearLayout>
